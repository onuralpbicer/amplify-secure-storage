{
  "name": "amplify-secure-storage",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/amplify-secure-storage/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}/dist"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "rootDir": "packages/amplify-secure-storage/src",
        "outputPath": "packages/amplify-secure-storage/dist",
        "main": "packages/amplify-secure-storage/src/index.ts",
        "tsConfig": "packages/amplify-secure-storage/tsconfig.lib.json",
        "assets": ["packages/amplify-secure-storage/*.md"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}/dist"
      }
    }
  }
}
